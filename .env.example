# ============================================================
# 环境变量模板 — 复制此文件为 .env.local 并填入真实 Key
# 此文件本身可以提交到 git（不含真实 Key）
# ============================================================

# Anthropic API Key（后端专用，永不暴露给浏览器）
# 获取地址: https://console.anthropic.com/settings/keys
# 线上部署: 在 Vercel 项目的 Settings → Environment Variables 中配置同名变量
ANTHROPIC_API_KEY=your_api_key_here

# VIP 邀请码（留空则关闭访问控制，任何人均可使用）
# 线上部署: 在 Vercel 项目的 Settings → Environment Variables 中配置同名变量
APP_ACCESS_CODE=your_invite_code_here
